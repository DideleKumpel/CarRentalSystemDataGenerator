<UserControl x:Class="CarRentalSystemDataGenerator.View.CrudeViews.CustomersCrudeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View.CrudeViews"
             xmlns:crudevm="clr-namespace:CarRentalSystemDataGenerator.ViewModel.CrudeViewModels"
             d:DataContext="{d:DesignInstance Type=crudevm:CustomersCrudeViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="ID"/>
                <TextBox Width="40" Margin="5"
                         Text="{Binding CustomerId}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Adress ID"/>
                <TextBox Width="40" Margin="5"
                         Text="{Binding AddressId}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Name"/>
                <TextBox Width="100" Margin="5"
                         Text="{Binding FirstName}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Last Name"/>
                <TextBox Width="150" Margin="5"
                         Text="{Binding LastName}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Email"/>
                <TextBox Width="150" Margin="5"
                         Text="{Binding Email}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="DriverLicenseNumber"/>
                <TextBox Width="150" Margin="5"
                         Text="{Binding DriverLicenseNum}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">
        <Button Content="Add Customer" Margin="5" Command="{Binding AddCustomerCommand}"/>
        <Button Content="Edit" Margin="5" Command="{Binding UpdateCustomerCommand}"/>
        <Button Content="Delete" Margin="5" Command="{Binding DeleteCustomerCommand}"/>
        <Button Content="Refresh" Margin="5" Command="{Binding LoadCustomersCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" Grid.Column="0"
                  ItemsSource="{Binding CustomerList}"
                  SelectedItem="{Binding SelectedCustomer}"
                  SelectionUnit="FullRow"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding CustomerID}" Width="2*"/>
                <DataGridTextColumn Header="Address Id" Binding="{Binding AddressID}" Width="2*"/>
                <DataGridTextColumn Header="FirstName" Binding="{Binding FirstName}" Width="5*"/>
                <DataGridTextColumn Header="LastName" Binding="{Binding LastName}" Width="5*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="7*"/>
                <DataGridTextColumn Header="DriverLicenseNum" Binding="{Binding DriverLicenseNum}" Width="5*"/>
            </DataGrid.Columns>
            
        </DataGrid>
    </Grid>
    
</UserControl>
