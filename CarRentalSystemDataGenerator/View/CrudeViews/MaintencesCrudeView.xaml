<UserControl x:Class="CarRentalSystemDataGenerator.View.CrudeViews.MaintencesCrudeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View.CrudeViews"
                      xmlns:crudevm="clr-namespace:CarRentalSystemDataGenerator.ViewModel.CrudeViewModels"
         d:DataContext="{d:DesignInstance Type=crudevm:MaintencesCrudeViewModel}"
         mc:Ignorable="d" 
     d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="ID"/>
                <TextBox Width="40" Margin="5"
                    Text="{Binding Id}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Car ID"/>
                <TextBox Width="40" Margin="5"
                    Text="{Binding CarId}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Maintence date"/>
                <DatePicker
            SelectedDate="{Binding MaintenceDate}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Cost"/>
                <TextBox Width="70" Margin="5"
                    Text="{Binding Cost}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Description"/>
                <TextBox Width="70" Margin="5"
                    Text="{Binding Description}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">
            <Button Content="Add Customer" Margin="5" Command="{Binding AddCommand}"/>
            <Button Content="Edit" Margin="5" Command="{Binding UpdateCommand}"/>
            <Button Content="Delete" Margin="5" Command="{Binding RemoveCommand}"/>
            <Button Content="Refresh" Margin="5" Command="{Binding LoadCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" Grid.Column="0"
  ItemsSource="{Binding List}"
  SelectedItem="{Binding Selected}"
  SelectionUnit="FullRow"
  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding MaintenanceID}" Width="2*"/>
                <DataGridTextColumn Header="Car Id" Binding="{Binding CarID}" Width="2*"/>
                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="3*"/>
                <DataGridTextColumn Header="Maintence date" Binding="{Binding MaintenanceDate}" Width="3*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="7*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
