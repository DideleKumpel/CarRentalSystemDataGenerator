<UserControl x:Class="CarRentalSystemDataGenerator.View.CrudeViews.EmployeesCrudeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View.CrudeViews"
             xmlns:crudevm="clr-namespace:CarRentalSystemDataGenerator.ViewModel.CrudeViewModels"
             d:DataContext="{d:DesignInstance Type=crudevm:EmployeesCrudeViewModel}"
             mc:Ignorable="d" 
         d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="ID"/>
                <TextBox Width="40" Margin="5"
                     Text="{Binding Id}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Office ID"/>
                <TextBox Width="40" Margin="5"
                     Text="{Binding OfficeId}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Name"/>
                <TextBox Width="100" Margin="5"
                     Text="{Binding FirstName}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Last Name"/>
                <TextBox Width="150" Margin="5"
                     Text="{Binding LastName}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Position"/>
                <TextBox Width="150" Margin="5"
                     Text="{Binding Position}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">
            <Button Content="Add Customer" Margin="5" Command="{Binding AddCommand}"/>
            <Button Content="Edit" Margin="5" Command="{Binding UpdateCommand}"/>
            <Button Content="Delete" Margin="5" Command="{Binding RemoveCommand}"/>
            <Button Content="Refresh" Margin="5" Command="{Binding LoadCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" Grid.Column="0"
              ItemsSource="{Binding Employees}"
              SelectedItem="{Binding SelectedEmployee}"
              SelectionUnit="FullRow"
              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
              AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding EmployeeID}" Width="2*"/>
                <DataGridTextColumn Header="Office Id" Binding="{Binding OfficeID}" Width="2*"/>
                <DataGridTextColumn Header="FirstName" Binding="{Binding FirstName}" Width="5*"/>
                <DataGridTextColumn Header="LastName" Binding="{Binding LastName}" Width="5*"/>
                <DataGridTextColumn Header="Positrion" Binding="{Binding Position}" Width="5*"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
