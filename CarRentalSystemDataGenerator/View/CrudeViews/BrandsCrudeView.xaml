<UserControl x:Class="CarRentalSystemDataGenerator.View.CrudeViews.BrandsCrudeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View.CrudeViews"
             xmlns:crudevm="clr-namespace:CarRentalSystemDataGenerator.ViewModel.CrudeViewModels"
             d:DataContext="{d:DesignInstance Type=crudevm:BrandsCrudeViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="ID"/>
                <TextBox Width="40" Margin="5"
                 Text="{Binding BrandId}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="5">
                <Label Content="Name"/>
                <TextBox Width="150" Margin="5"
                 Text="{Binding BrandName}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">
            <Button Content="Add Customer" Margin="5" Command="{Binding AddBrandCommand}"/>
            <Button Content="Edit" Margin="5" Command="{Binding UpdateBrandCommand}"/>
            <Button Content="Delete" Margin="5" Command="{Binding RemoveBrandCommand}"/>
            <Button Content="Refresh" Margin="5" Command="{Binding LoadBrandsCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" Grid.Column="0"
          ItemsSource="{Binding BrandsList}"
          SelectedItem="{Binding BrandSelected}"
          SelectionUnit="FullRow"
          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
          AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding BrandID}" Width="2*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="7*"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
