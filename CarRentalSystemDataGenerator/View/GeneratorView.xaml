<UserControl x:Class="CarRentalSystemDataGenerator.View.GeneratorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View"
      xmlns:viewmodel="clr-namespace:CarRentalSystemDataGenerator.ViewModel"
      d:DataContext="{d:DesignInstance Type=viewmodel:GeneratorViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="CarRentDB data generator" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32"/>
        <Label Grid.Row="1" Content="Select the tables you want to generate data for" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <CheckBox Content="Adresses" IsChecked="{Binding AdressesIsChecked}"/>
            <CheckBox Grid.Row="1" Content="Brands" IsChecked="{Binding BrandsIsChecked}"/>
            <CheckBox Grid.Row="2" Content="Cars" IsChecked="{Binding CarsIsChecked}"/>
            <CheckBox Grid.Row="3" Content="Customers" IsChecked="{Binding CustomersIsChecked}"/>
            <CheckBox Grid.Row="4" Content="Employees" IsChecked="{Binding EmployeesIsChecked}"/>
            <CheckBox Grid.Row="5" Content="Maintenances" IsChecked="{Binding MaintenancesIsChecked}"/>
            <CheckBox Grid.Column="1" Content="Models" IsChecked="{Binding ModelsIsChecked}"/>
            <CheckBox Grid.Row="1" Grid.Column="1" Content="Offices" IsChecked="{Binding OfficesIsChecked}"/>
            <CheckBox Grid.Row="2" Grid.Column="1" Content="Payments" IsChecked="{Binding PaymentsIsChecked}"/>
            <CheckBox Grid.Row="3" Grid.Column="1" Content="Rentals" IsChecked="{Binding RentalsIsChecked}"/>
        </Grid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Height="30">
            <Label Content="Write number of records to generate "/>
            <TextBox Width="100" Margin="5" Text="{Binding NumOfRecordToGenreate, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <Button Grid.Row="4" Content="Generate data" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Height="40" Command="{Binding GenerateDataCommand}"/>

    </Grid>
</UserControl>
