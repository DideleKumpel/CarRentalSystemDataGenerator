<UserControl x:Class="CarRentalSystemDataGenerator.View.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View"
             xmlns:vm="clr-namespace:CarRentalSystemDataGenerator.ViewModel"
             d:DataContext="{d:DesignInstance Type=vm:ExportViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Button Content="Back" Command="{Binding BackToMainWindowCommand}"
                Width="50" Height="30" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Label Content="CarRentDB data export import" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32"/>
        <Label Grid.Row="2" Content="Select file location"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5" Height="50">
            <TextBox Width="300" Margin="0,10" IsReadOnly="True" Text="{Binding FileExport}"/>
            <Button Content="Browse" Margin="5,10" Command="{Binding CreateFileCommand}"/>
        </StackPanel>
        <Button Grid.Row="6" Height="30" Width="50"
                Content="Export" Command="{Binding ExportToJsonCommand}"/>
        <Label Grid.Row="7" Content="Select file to import"/>
        <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="5" Height="50">
            <TextBox Width="300" Margin="0,10" IsReadOnly="True" Text="{Binding FileImport}"/>
            <Button Content="Browse" Margin="5,10" Command="{Binding ChooseFileCommand}"/>
        </StackPanel>
        <Button Grid.Row="9" Height="30" Width="50"
            Content="Import" Command="{Binding ImportFromJsonCommand}"/>
    </Grid>
</UserControl>
