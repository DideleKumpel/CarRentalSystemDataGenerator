<UserControl x:Class="CarRentalSystemDataGenerator.View.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarRentalSystemDataGenerator.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Button Content="Back" Command="{Binding BackToMainWindowCommand}"
                Width="50" Height="30" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Label Content="CarRentDB data export" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32"/>
        <Label Grid.Row="1"
            Content="Select format" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
            <RadioButton Content="xml" GroupName="ExportFormat" Margin="0,10"/>
            <RadioButton Content="json" GroupName="ExportFormat" Margin="0,10"/>
        </StackPanel>
        <Label Grid.Row="3" Content="Select file location"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5" Height="50">
            <TextBox Width="300" Margin="0,10" IsReadOnly="True"/>
            <Button Content="Browse" Margin="5,10"/>
        </StackPanel>
        <Label Grid.Row="5" Content="File name:"/>
        <TextBox Grid.Row="6" Width="300" Margin="0,10" HorizontalAlignment="Left"/>
        <Button Grid.Row="7" Height="30" Width="50"
                Content="Export"/>
    </Grid>
</UserControl>
