<Window x:Class="CarRentalSystemDataGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarRentalSystemDataGenerator" 
        xmlns:views="clr-namespace:CarRentalSystemDataGenerator.View"
        xmlns:viewmodels="clr-namespace:CarRentalSystemDataGenerator.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <DataTemplate x:Name="MainMenuTemplate" DataType="{x:Type viewmodels:MainMenuViewModel}">
            <views:MainMenuView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate x:Name="ExportImportTemplate" DataType="{x:Type viewmodels:ExportViewModel}">
            <views:ExportView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate x:Name="GeneratorTemplate" DataType="{x:Type viewmodels:GeneratorViewModel}">
            <views:GeneratorView DataContext="{Binding}"/>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <ContentControl Content="{Binding}"/>
    </Grid>
</Window>
