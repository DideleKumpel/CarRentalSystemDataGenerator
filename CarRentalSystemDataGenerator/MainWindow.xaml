<Window x:Class="CarRentalSystemDataGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarRentalSystemDataGenerator" 
        xmlns:viewmodel="clr-namespace:CarRentalSystemDataGenerator.ViewModel" 
        d:DataContext="{d:DesignInstance Type=viewmodel:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Label Content="CarRenDB" />
        <Button Grid.Row="1" Width="150" Height="40" Margin="0,10"
                Content="Generate data"
                Command="{Binding SwitchToGeneratorViewCommand}"/>
        <Button Grid.Row="2" Content="Data view" Width="150" Height="40" Margin="0,10"/>

    </Grid>
</Window>
